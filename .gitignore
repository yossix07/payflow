# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of version 
# control as they are data points which are potentially sensitive and subject 
# to change depending on the environment.
*.tfvars
*.tfvars.json

# Override files which are usually used to override resources locally and so
# are not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include override files you do wish to add to version control using negated pattern
# !example_override.tf

# CLI configuration files
.terraformrc
terraform.rc

# Local Environment Variables (Secrets)
.aws.env
.env

# Kubernetes
kubeconfig
*.kube

# Node.js
node_modules/
*.log
.env.local
.env.*.local

# OS files
.DS_Store
Thumbs.db

# Claude Code IDE settings
.claude/

# AWS cost/budget config (personal)
budget.json
daily_filter.json
filter.json
notifications.json

# Personal drafts
linkedin_post_draft.md
